{
  "name": "dental-place",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently 'next dev' 'pnpm codegen:dev'",
    "build": "pnpm run codegen:prod && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "release": "release-it",
    "codegen": "graphql-codegen --config",
    "codegen:prod": "pnpm run codegen -- codegen.prod.ts",
    "codegen:dev": "pnpm run codegen -- codegen.dev.ts --watch"
  },
  "dependencies": {
    "@apollo/client": "^3.11.3",
    "@apollo/experimental-nextjs-app-support": "^0.12.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.28.0",
    "embla-carousel-auto-scroll": "^8.1.6",
    "embla-carousel-autoplay": "^8.1.6",
    "embla-carousel-react": "^8.1.6",
    "graphql": "^16.9.0",
    "html-react-parser": "^6.1.1",
    "isomorphic-dompurify": "^3.14.0",
    "lucide-react": "^0.400.0",
    "next": "^15.5.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.52.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@graphql-codegen/introspection": "6.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@parcel/watcher": "^2.4.1",
    "@release-it/bumper": "5.0.0",
    "@release-it/conventional-changelog": "7.0.0",
    "@types/node": "^18.6.3",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "10.4.7",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "postcss": "8.4.31",
    "release-it": "16.2.1",
    "tailwindcss": "^3.0.24",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.4"

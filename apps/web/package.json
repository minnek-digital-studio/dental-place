{
  "name": "@minnek/web",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "concurrently 'next' 'pnpm codegen:dev'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "release": "release-it",
    "codegen": "graphql-codegen --config",
    "codegen:prod": "npm run codegen -- codegen.prod.ts",
    "codegen:dev": "npm run codegen -- codegen.dev.ts --watch"
  },
  "dependencies": {
    "@apollo/client": "^3.11.3",
    "@apollo/experimental-nextjs-app-support": "^0.11.2",
    "@hookform/resolvers": "^3.9.0",
    "@minnek/typescript-config": "workspace:*",
    "@minnek/ui": "workspace:*",
    "classnames": "^2.3.1",
    "date-fns": "^2.28.0",
    "graphql": "^16.9.0",
    "next": "latest",
    "next-transpile-modules": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/client-preset": "4.3.3",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/typescript": "^4.0.9",
    "@graphql-codegen/typescript-operations": "^4.2.3",
    "@graphql-codegen/typescript-react-apollo": "^4.3.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@parcel/watcher": "^2.4.1",
    "@types/node": "^18.6.3",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "autoprefixer": "10.4.7",
    "classnames": "^2.3.1",
    "concurrently": "^8.2.2",
    "date-fns": "^2.28.0",
    "postcss": "8.4.31",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.0.24",
    "@minnek/config-release-it": "workspace:*"
  }
}

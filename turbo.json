{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "globalEnv": ["WORDPRESS_API_URL", "WORDPRESS_DOMAIN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^lint", "^test"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "release": {
      "dependsOn": ["^release"]
    }
  }
}
